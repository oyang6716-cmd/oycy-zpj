                                    <div key={idx} className="flex items-center gap-8 group leading-none">
                                        <div className="w-14 h-14 bg-white/5 border border-white/5 rounded-2xl flex items-center justify-center text-cyan-400 group-hover:shadow-[0_0_60px_rgba(0,255,255,0.4)] group-hover:bg-cyan-600 group-hover:text-white transition-all transform group-hover:rotate-12 shadow-2xl leading-none align-middle"><Icon name={item.i} size={28}/></div>
                                        <div className="flex flex-col gap-2"><p className="text-[11px] font-black text-white/20 uppercase tracking-[0.4em] mb-2 leading-none">{item.l}</p><p className="text-xl font-bold text-white group-hover:text-cyan-400 transition-all uppercase leading-none">{item.v}</p></div>
                                    </div>
                                ))}
                            </div>
                            <button className="bg-white text-black font-black px-16 py-4 rounded-lg hover:bg-cyan-600 hover:text-white transition-all tracking-[0.6em] text-[13px] uppercase active:scale-95 flex items-center gap-6 mx-auto relative z-10 shadow-2xl shadow-white/5 group leading-none align-middle"><Icon name="Send" size={24} className="group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" /> 发送咨询</button>
                        </div>
                    </section>

                    <footer className="py-24 border-t border-white/5 text-center relative z-10 bg-black/80 opacity-30 group hover:opacity-100 transition-opacity">
                        <div className="flex items-center justify-center gap-4 text-white leading-none align-middle"><Icon name="Copyright" size={20} className="text-cyan-400" /> <span className="text-[11px] font-black tracking-[0.8em] uppercase leading-none align-middle">OU YANG CHEN YAN | 2022-2026</span></div>
                    </footer>

                    {/* Viewport Modal */}
                    <AnimatePresence>
                        {selectedProject && (
                            <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} className="fixed inset-0 z-[1100] bg-black/98 backdrop-blur-3xl overflow-y-auto px-6 md:px-24 py-24 custom-scrollbar text-left text-white">
                                <div className="max-w-screen-xl mx-auto relative">
                                    <button onClick={() => setSelectedProject(null)} className="fixed top-12 right-12 z-[1110] w-14 h-14 rounded-full glass-card border border-white/10 flex items-center justify-center text-white hover:bg-red-500 transition-all shadow-2xl active:scale-90 text-white"><Icon name="X" size={32} /></button>
                                    <div className="space-y-24 text-left">
                                        <div className="max-w-4xl text-left text-white">
                                            <div className="flex items-center gap-4 text-cyan-400 text-[13px] font-black tracking-[0.6em] uppercase mb-8 align-middle"><Icon name="Layers" size={18}/> {selectedProject.category}</div>
                                            <h2 className="text-4xl md:text-7xl font-black text-white mb-16 tracking-tighter leading-none uppercase border-b-2 border-white/5 pb-20 shadow-2xl">{selectedProject.title}</h2>
                                            <div className="p-12 glass-card shadow-2xl relative overflow-hidden bg-white/[0.03]">
                                                <div className="absolute top-0 left-0 w-full h-1 bg-cyan-600 shadow-[0_0_20px_#00ffff]"></div>
                                                <p className="text-xl md:text-2xl text-white/80 leading-[2.6] font-medium whitespace-pre-wrap tracking-wide">{selectedProject.desc}</p>
                                            </div>
                                        </div>
                                        <div className="grid grid-cols-1 gap-16 pb-48">
                                            {selectedProject.media?.map((m, i) => <motion.div initial={{y:100, opacity:0}} whileInView={{y:0, opacity:1}} transition={{duration:1.2}} key={i} className="rounded-2xl overflow-hidden border border-white/10 bg-black shadow-[0_60px_120px_rgba(0,0,0,0.9)] text-white">{renderMediaItem(m, "w-full h-auto max-h-[95vh] object-contain shadow-2xl", true)}</motion.div>)}
                                        </div>
                                    </div>
                                </div>
                            </motion.div>
                        )}
                    </AnimatePresence>

                    {/* Auth Modal */}
                    <AnimatePresence>
                        {showAuthModal && (
                            <motion.div initial={{ opacity: 0 }} animate={{ opacity: 1 }} exit={{ opacity: 0 }} className="fixed inset-0 z-[1200] flex items-center justify-center bg-black/95 backdrop-blur-3xl px-6 text-white text-center">
                                <div className="bg-[#111] border border-white/10 p-16 rounded-[40px] max-w-xl w-full text-center shadow-2xl border-cyan-500/20 relative">
                                    <div className="w-20 h-20 bg-cyan-600 text-white flex items-center justify-center rounded-full mx-auto mb-10 shadow-[0_0_60px_rgba(0,255,255,0.4)] animate-pulse shadow-black"><Icon name="Lock" size={40} /></div>
                                    <h3 className="text-4xl font-black mb-6 uppercase text-white tracking-[0.2em] shadow-2xl">身份验证</h3>
                                    <input type="password" value={passcode} onChange={(e) => setPasscode(e.target.value)} placeholder="••••••" className="w-full bg-black/40 border border-white/10 rounded-xl px-10 py-6 mb-16 focus:outline-none focus:border-cyan-500 text-center tracking-[1em] text-4xl text-white font-black shadow-inner shadow-black" />
                                    <div className="flex gap-8"><button onClick={() => setShowAuthModal(false)} className="flex-1 py-6 text-xs font-black text-white/20 hover:text-white uppercase transition-all tracking-widest">取消</button><button onClick={handleAuth} className="flex-1 bg-cyan-600 text-white py-6 rounded-xl text-xs font-black hover:shadow-[0_0_40px_#00ffff] uppercase active:scale-95 transition-all tracking-widest">确认解锁</button></div>
                                </div>
                            </motion.div>
                        )}
                    </AnimatePresence>

                    <div className="fixed bottom-12 right-12 z-[100] flex gap-8 leading-none align-middle">
                        <button onClick={toggleMusic} className={`w-16 h-16 rounded-full flex items-center justify-center transition-all duration-1000 border border-white/10 shadow-2xl ${isPlaying ? 'bg-cyan-600 text-white scale-110 shadow-[0_0_30px_#00ffff]' : 'bg-black/50 backdrop-blur-md text-white/20'}`}>{isPlaying ? <Icon name="Volume2" size={24} /> : <Icon name="VolumeX" size={24} />}</button>
                    </div>
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
