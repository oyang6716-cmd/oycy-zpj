        const InteractiveLetter = ({ char, mouseX, mouseY }) => {
            const ref = useRef(null);
            const x = useSpring(0, { stiffness: 100, damping: 20 });
            const y = useSpring(0, { stiffness: 100, damping: 20 });
            const blur = useSpring(0, { stiffness: 100, damping: 20 });
            useEffect(() => {
                const update = () => {
                    if (!ref.current) return;
                    const rect = ref.current.getBoundingClientRect();
                    const centerX = rect.left + rect.width / 2;
                    const centerY = rect.top + rect.height / 2;
                    const dx = mouseX.get() - centerX;
                    const dy = mouseY.get() - centerY;
                    const distance = Math.sqrt(dx * dx + dy * dy);
                    const radius = window.innerWidth * 0.18; 
                    if (distance < radius) {
                        const power = Math.pow(1 - distance / radius, 2);
                        x.set(dx * 0.08 * power); y.set(dy * 0.08 * power);
                        blur.set(power * 15);
                    } else {
                        x.set(0); y.set(0); blur.set(0);
                    }
                };
                const unX = mouseX.on("change", update);
                const unY = mouseY.on("change", update);
                return () => { unX(); unY(); };
            }, [mouseX, mouseY, x, y, blur]);
            const filterStr = useTransform(blur, (v) => `blur(${v}px)`);
            return <motion.span ref={ref} style={{ x, y, filter: filterStr, display: 'inline-block' }}>{char}</motion.span>;
        };

